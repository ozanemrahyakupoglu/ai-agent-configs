{
  "mcpServers": {
    "jira": {
      "command": "npx",
      "args": [
        "-y",
        "@aashari/mcp-server-atlassian-jira"
      ],
      "env": {
        "ATLASSIAN_SITE_NAME": "ozanemrahyakupoglu",
        "ATLASSIAN_USER_EMAIL": "ai.developer@onbtech.com",
        "ATLASSIAN_API_TOKEN": "$JIRA_API_KEY"
      }
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "$GITHUB_TOKEN"
      }
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ]
    },
    "postgres": {
      "command": "npx",
      "args": [
        "-y",
        "@crystaldba/postgres-mcp",
        "--access-mode",
        "unrestricted"
      ],
      "env": {
        "DATABASE_URI": "$DATABASE_URI"
      }
    }
  }
}
